local API_BASE   = "https://latteclientscript-1.onrender.com"        -- your Render URL (no trailing slash)
local API_SECRET = "314942852849948194857818785219589215781585281758218484748828289"    -- must match .env API_SECRET

API_BASE = API_BASE:gsub("/+$", "")

-- ---- services ---------------------------------------------
local Players     = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local LP          = Players.LocalPlayer

local function kick(reason)
    pcall(function() LP:Kick("\n[IceLatte] " .. reason) end)
    -- Stop the rest of the script from running after a kick request
    error("[IceLatte] " .. reason, 0)
end

-- ---- executor compatibility shims -------------------------
-- Madium needs a gethui() that points at CoreGui, otherwise the menu
-- can fail to parent correctly.
pcall(function()
    if identifyexecutor and identifyexecutor() == "Madium" then
        print("its okay my cutie pie ur executor is supported now be a good boy for mommy")
        getgenv().gethui = function()
            return game:GetService("CoreGui")
        end
    end
end)

-- ---- HWID -------------------------------------------------
local function getHWID()
    local id
    pcall(function()
        if gethwid then id = gethwid() end
    end)
    if not id or id == "" then
        -- fallback: stable per-install id stored on disk
        pcall(function()
            if isfile and readfile and isfile("IceLatte/hwid.txt") then
                id = readfile("IceLatte/hwid.txt")
            elseif writefile then
                id = HttpService:GenerateGUID(false)
                if makefolder and not (isfolder and isfolder("IceLatte")) then makefolder("IceLatte") end
                writefile("IceLatte/hwid.txt", id)
            end
        end)
    end
    return id or "unknown"
end

-- ---- main -------------------------------------------------
-- 1) Find the key the user set. Accept getgenv().key or a global `key`.
local key = (getgenv and getgenv().key) or (rawget(getfenv(0), "key"))
if type(key) ~= "string" or key == "" then
    kick("Couldn't find key. Set it before loading:\n\ngetgenv().key = \"YOUR-KEY-HERE\"")
end

-- 2) Ask the server for the client. The server validates the key + HWID and
--    returns the real script ONLY if the key is valid; otherwise it returns a
--    tiny snippet that kicks the player. The real source never sits at a
--    public URL, so an expiring GitHub raw link is no longer a problem.
local hwid = getHWID()
local url = string.format(
    "%s/script?key=%s&hwid=%s&secret=%s",
    API_BASE,
    HttpService:UrlEncode(key),
    HttpService:UrlEncode(hwid),
    HttpService:UrlEncode(API_SECRET)
)

local src
local sok = pcall(function() src = game:HttpGet(url) end)
if not sok or type(src) ~= "string" or #src == 0 then
    kick("Couldn't reach the key server. Try again in a moment.")
end

-- 3) Run whatever came back (real client, or the server's kick snippet).
local fn, err = loadstring(src)
if not fn then
    kick("Client failed to compile: " .. tostring(err))
end
fn()
